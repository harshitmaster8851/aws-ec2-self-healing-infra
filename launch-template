#Bootstraps an EC2 instance by installing Python/Flask, deploying a simple health-check web app, streaming its logs to Amazon CloudWatch, and running it in the background.

#!/bin/bash

yum update -y

# Install python + pip
yum install python3 -y
yum install python3-pip -y

# Install flask
pip3 install flask

# Install CloudWatch agent
yum install amazon-cloudwatch-agent -y

# Create Flask app
cat <<EOF > /home/ec2-user/app.py
from flask import Flask
app = Flask(__name__)

@app.route('/')
def home():
    return "App is running"

@app.route('/health')
def health():
    return {"status": "ok"}, 200

app.run(host="0.0.0.0", port=5000)
EOF

# Run app
nohup python3 /home/ec2-user/app.py > /home/ec2-user/output.log 2>&1 &

# Create CloudWatch config
cat <<EOF > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/ec2-user/output.log",
            "log_group_name": "selfheal-app-logs",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
EOF

# Start CloudWatch agent
/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
-a fetch-config \
-m ec2 \
-c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
-s
